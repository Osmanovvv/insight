# ──────────────────────────────────────────────
#  Insight IS — Environment Variables Template
#  Скопируйте этот файл в .env и заполните значения
# ──────────────────────────────────────────────

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@localhost:5432/INSIGHT

# JWT (сгенерируйте свой секрет: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# News API Keys (опционально — если оставить пустыми, будет работать только RSS РИА)
NEWS_API_KEY=
NEWS_DATA_API_KEY=
MEDIASTACK_API_KEY=
GNEWS_API_KEY=

# Financial API Keys (опционально)
ALPHA_VANTAGE_KEY=
POLYGON_KEY=
FINNHUB_KEY=

# AI — Google Gemini (получить на https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# App
DEBUG=True
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
